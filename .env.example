# --- FulcrumCards · variables de entorno ---
# Copia a .env y rellena. En Vercel, añade estas mismas claves en Project Settings → Environment Variables.

# MongoDB Atlas — base de datos `fulcrumcards`, colección `fichas`
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/fulcrumcards?retryWrites=true&w=majority

# Claude API — generación de cards (Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-...

# Auth del panel admin (JWT + bcrypt)
JWT_SECRET=una-cadena-larga-y-aleatoria
ADMIN_USER=carles

# Hash bcrypt del password de admin.
#  ⚠️ En el .env LOCAL escapa cada "$" como "\$" (Next usa dotenv-expand y si no, corrompe el hash).
#  ⚠️ En VERCEL pega el hash CRUDO, sin barras invertidas (Vercel no expande variables).
ADMIN_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
